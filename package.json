{
  "name": "agsystems",
  "version": "0.0.1",
  "description": "A starter for TinaCMS with Hugo",
  "main": "index.js",
  "scripts": {
    "dev": "tinacms dev -c \"hugo server -D\"",
    "build": "tinacms build && hugo",
    "build-local": "tinacms build --local --skip-indexing --skip-cloud-checks && hugo",
    "test": "echo \"Error: no test specified\" && exit 1",
    "tinacms": "tinacms build",
    "dev:theme:hextra": "hugo server --logLevel=debug --config=hugo.yaml,../dev.toml --environment=theme --source=exampleSite --themesDir=../.. -D --port 1313",
    "dev:hextra": "hugo server --source=exampleSite --themesDir=../.. --disableFastRender -D --port 1313",
    "build:css:hextra": "npx postcss --config postcss.config.mjs --env production assets/css/styles.css -o assets/css/compiled/main.css",
    "build:hextra": "hugo --gc --minify --themesDir=../.. --source=exampleSite"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinalabs/vanilla-hugo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tinalabs/vanilla-hugo/issues"
  },
  "homepage": "https://github.com/tinalabs/vanilla-hugo#readme",
  "dependencies": {
    "@tinacms/auth": "^1.0.12",
    "@tinacms/cli": "^1.9.7",
    "next-tinacms-cloudinary": "^13.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tinacms": "^2.7.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.23",
    "@tailwindcss/postcss": "^4.0.17",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.5.3",
    "prettier-plugin-go-template": "^0.0.15",
    "tailwindcss": "^4.0.17"
  }
}
